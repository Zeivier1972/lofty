generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  password     String
  role         String    @default("AGENT")
  avatar       String?
  phone        String?
  title        String?
  bio          String?
  timezone     String    @default("America/New_York")
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  contacts     Contact[]
  tasks        Task[]
  activities   Activity[]
  appointments Appointment[]
  transactions Transaction[]
  notes        Note[]
  emails       Email[]
  smartPlans   SmartPlan[]
  availability Availability[]
  availabilityBlocks AvailabilityBlock[]
}

model Availability {
  id          String   @id @default(cuid())
  dayOfWeek   Int      // 0=Sun 1=Mon 2=Tue 3=Wed 4=Thu 5=Fri 6=Sat
  startTime   String   // "09:00"
  endTime     String   // "17:00"
  isAvailable Boolean  @default(true)
  slotMinutes Int      @default(30)
  user        User?    @relation(fields: [userId], references: [id])
  userId      String?
  createdAt   DateTime @default(now())
}

model AvailabilityBlock {
  id        String   @id @default(cuid())
  date      String   // "YYYY-MM-DD"
  startTime String?  // null = full day block
  endTime   String?
  reason    String?
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
  createdAt DateTime @default(now())
}

model Contact {
  id            String    @id @default(cuid())
  firstName     String
  lastName      String
  email         String?
  phone         String?
  phone2        String?
  address       String?
  city          String?
  state         String?
  zip           String?
  country       String?
  source        String?
  status        String    @default("LEAD")
  leadScore     Int       @default(0)
  rating        Int       @default(0)
  birthday      DateTime?
  anniversary   DateTime?
  spouse        String?
  company       String?
  jobTitle      String?
  website       String?
  socialFacebook String?
  socialInstagram String?
  socialLinkedin String?
  socialTwitter  String?
  doNotCall     Boolean   @default(false)
  doNotEmail    Boolean   @default(false)
  doNotText     Boolean   @default(false)
  smsTCPAConsent       Boolean   @default(false)
  smsTCPAConsentDate   DateTime?
  smsTCPAConsentMethod String?
  isArchived    Boolean   @default(false)
  lastContacted DateTime?
  homeClosedAt        DateTime?
  preferredSendHour   Int?
  facebookLeadId      String?
  facebookPsid        String?
  instagramIgsid      String?
  lastScoreCalculatedAt DateTime?
  buyerBudgetMin Float?
  buyerBudgetMax Float?
  buyerBedroomsMin Int?
  buyerBathroomsMin Float?
  buyerPropertyType String?
  buyerMustHaves    String?
  buyerLocation String?
  buyerTimelineMonths   Int?
  buyerPurpose          String?
  matchPrefsCompletedAt DateTime?
  sellerAddress String?
  sellerEstimatedValue Float?
  notes         Note[]
  tasks         Task[]
  activities    Activity[]
  emails        Email[]
  appointments  Appointment[]
  transactions  Transaction[]
  pipelineLeads PipelineLead[]
  enrollments   SmartPlanEnrollment[]
  propertyInterests PropertyInterest[]
  propertySaves PropertySave[]
  propertyViews PropertyView[]
  searchBehaviors SearchBehavior[]
  aiConversations AIConversation[]
  aiNotifications AINotification[]
  dialerCalls   DialerCall[]
  campaignEnrollments CampaignEnrollment[]
  whatsappMessages WhatsAppMessage[]
  facebookMessages FacebookMessage[]
  videoMessages VideoMessage[]
  portalAccess  ClientPortalAccess?
  portalMessages PortalMessage[]
  tags          ContactTag[]
  scheduledCalls ScheduledCall[]
  leadShares    LeadShare[]
  leadMagnetDeliveries LeadMagnetDelivery[]
  assignedTo    User?     @relation(fields: [assignedToId], references: [id])
  assignedToId  String?
  customFields  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Tag {
  id        String       @id @default(cuid())
  name      String       @unique
  color     String       @default("#3B82F6")
  contacts  ContactTag[]
  createdAt DateTime     @default(now())
}

model ContactTag {
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId String
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId     String
  @@id([contactId, tagId])
}

model Pipeline {
  id        String          @id @default(cuid())
  name      String
  isDefault Boolean         @default(false)
  color     String          @default("#3B82F6")
  stages    PipelineStage[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model PipelineStage {
  id         String         @id @default(cuid())
  name       String
  order      Int
  color      String         @default("#3B82F6")
  rotPercent Float?
  pipeline   Pipeline       @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  pipelineId String
  leads      PipelineLead[]
}

model PipelineLead {
  id            String        @id @default(cuid())
  contact       Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId     String
  stage         PipelineStage @relation(fields: [stageId], references: [id])
  stageId       String
  value         Float?
  probability   Int?
  expectedClose DateTime?
  notes         String?
  priority      String        @default("MEDIUM")
  enteredAt     DateTime      @default(now())
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Property {
  id            String    @id @default(cuid())
  mlsId         String?
  title         String?
  address       String
  city          String
  state         String
  zip           String
  price         Float
  originalPrice Float?
  bedrooms      Int?
  bathrooms     Float?
  sqft          Int?
  lotSize       Float?
  yearBuilt     Int?
  propertyType  String    @default("SINGLE_FAMILY")
  status        String    @default("ACTIVE")
  description   String?
  images        String?
  features      String?
  garage        Int?
  pool          Boolean   @default(false)
  hoa           Float?
  taxes         Float?
  listingDate   DateTime?
  expiryDate    DateTime?
  daysOnMarket  Int?
  agentName     String?
  agentPhone    String?
  agentEmail    String?
  office        String?
  latitude      Float?
  longitude     Float?
  interests     PropertyInterest[]
  saves         PropertySave[]
  views         PropertyView[]
  openHouses    OpenHouse[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model PropertyInterest {
  id          String    @id @default(cuid())
  contact     Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId   String
  property    Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId  String
  type        String    @default("VIEWED")
  notes       String?
  createdAt   DateTime  @default(now())
}

model Task {
  id           String    @id @default(cuid())
  title        String
  description  String?
  dueDate      DateTime?
  dueTime      String?
  priority     String    @default("MEDIUM")
  status       String    @default("PENDING")
  type         String    @default("FOLLOW_UP")
  contact      Contact?  @relation(fields: [contactId], references: [id])
  contactId    String?
  assignedTo   User?     @relation(fields: [assignedToId], references: [id])
  assignedToId String?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Activity {
  id          String    @id @default(cuid())
  type        String
  title       String
  description String?
  contact     Contact?  @relation(fields: [contactId], references: [id])
  contactId   String?
  user        User?     @relation(fields: [userId], references: [id])
  userId      String?
  metadata    String?
  createdAt   DateTime  @default(now())
}

model Note {
  id          String    @id @default(cuid())
  content     String
  isPinned    Boolean   @default(false)
  contact     Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId   String
  author      User?     @relation(fields: [authorId], references: [id])
  authorId    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Appointment {
  id          String    @id @default(cuid())
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  location    String?
  type        String    @default("SHOWING")
  status      String    @default("SCHEDULED")
  reminder    Int?
  virtualLink String?
  contact     Contact?  @relation(fields: [contactId], references: [id])
  contactId   String?
  user        User?     @relation(fields: [userId], references: [id])
  userId      String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Email {
  id          String         @id @default(cuid())
  subject     String
  body        String
  fromAddress String
  toAddress   String
  direction   String         @default("OUTBOUND")
  status      String         @default("DRAFT")
  contact     Contact?       @relation(fields: [contactId], references: [id])
  contactId   String?
  user        User?          @relation(fields: [userId], references: [id])
  userId      String?
  template    EmailTemplate? @relation(fields: [templateId], references: [id])
  templateId  String?
  sentAt      DateTime?
  openedAt    DateTime?
  clickedAt   DateTime?
  createdAt   DateTime       @default(now())
}

model EmailTemplate {
  id        String   @id @default(cuid())
  name      String
  subject   String
  body      String
  category  String?
  isShared  Boolean  @default(false)
  emails    Email[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SMSMessage {
  id          String    @id @default(cuid())
  body        String
  fromNumber  String
  toNumber    String
  direction   String    @default("OUTBOUND")
  status      String    @default("SENT")
  contactId   String?
  userId      String?
  createdAt   DateTime  @default(now())
}

model Transaction {
  id            String    @id @default(cuid())
  title         String
  address       String
  city          String
  state         String
  zip           String
  type          String    @default("BUYER")
  status        String    @default("ACTIVE_LISTING")
  salePrice     Float?
  listPrice     Float?
  commission    Float?
  commissionPercent Float?
  closeDate     DateTime?
  contractDate  DateTime?
  listingDate   DateTime?
  expirationDate DateTime?
  mlsNumber     String?
  notes         String?
  earnestMoney        Float?
  earnestMoneyDueDate DateTime?
  commissionSplit     String?
  coAgentName         String?
  coAgentEmail        String?
  coAgentCommission   Float?
  contact       Contact?  @relation(fields: [contactId], references: [id])
  contactId     String?
  agent         User?     @relation(fields: [agentId], references: [id])
  agentId       String?
  milestones    TransactionMilestone[]
  documents     TransactionDocument[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model TransactionMilestone {
  id            String      @id @default(cuid())
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  transactionId String
  name          String
  dueDate       DateTime?
  completedDate DateTime?
  status        String      @default("PENDING")
  notes         String?
  order         Int         @default(0)
}

model TransactionDocument {
  id            String      @id @default(cuid())
  name          String
  url           String
  fileType      String?
  fileSize      Int?
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  transactionId String
  uploadedAt    DateTime    @default(now())
}

model SmartPlan {
  id          String                @id @default(cuid())
  name        String
  description String?
  trigger     String                @default("MANUAL")
  isActive    Boolean               @default(true)
  steps       SmartPlanStep[]
  enrollments SmartPlanEnrollment[]
  user        User?                 @relation(fields: [userId], references: [id])
  userId      String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
}

model SmartPlanStep {
  id        String    @id @default(cuid())
  plan      SmartPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  planId    String
  order     Int
  type      String    @default("EMAIL")
  delay     Int       @default(1)
  subject   String?
  content   String?
  taskType  String?
  taskTitle String?
  isActive  Boolean   @default(true)
}

model SmartPlanEnrollment {
  id          String    @id @default(cuid())
  plan        SmartPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  planId      String
  contact     Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId   String
  currentStep Int       @default(0)
  status      String    @default("ACTIVE")
  enrolledAt  DateTime  @default(now())
  completedAt DateTime?
  nextStepAt  DateTime?
}

model MarketingCampaign {
  id          String    @id @default(cuid())
  name        String
  type        String    @default("EMAIL")
  status      String    @default("DRAFT")
  subject     String?
  content     String?
  scheduledAt DateTime?
  sentAt      DateTime?
  recipients      Int       @default(0)
  opened          Int       @default(0)
  clicked         Int       @default(0)
  subjectVariantB String?
  openedVariantA  Int       @default(0)
  openedVariantB  Int       @default(0)
  winnerVariant   String?
  audience        String?
  tagIds          String?
  enrollments CampaignEnrollment[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model LeadSource {
  id        String    @id @default(cuid())
  name      String    @unique
  color     String    @default("#3B82F6")
  icon      String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
}

// ─── AI Agent ─────────────────────────────────────────────────────────────────

model AIConversation {
  id          String      @id @default(cuid())
  contactId   String
  contact     Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  status      String      @default("ACTIVE")
  channel     String      @default("SMS")
  lastMessage String?
  messages    AIMessage[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model AIMessage {
  id             String         @id @default(cuid())
  conversation   AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  conversationId String
  role           String
  content        String
  channel        String         @default("INTERNAL")
  delivered      Boolean        @default(false)
  deliveredAt    DateTime?
  createdAt      DateTime       @default(now())
}

model AINotification {
  id          String    @id @default(cuid())
  title       String
  body        String
  type        String    @default("ACTION")
  priority    String    @default("MEDIUM")
  contactId   String?
  contact     Contact?  @relation(fields: [contactId], references: [id])
  isRead      Boolean   @default(false)
  metadata    String?
  createdAt   DateTime  @default(now())
}

model AIConfig {
  id              String   @id @default(cuid())
  agentName       String   @default("Sofia")
  agentPersona    String   @default("Eres Sofia, una asistente virtual de bienes raíces amigable y profesional que trabaja para Catherine. Hablas principalmente español y ayudas a los clientes a encontrar su hogar ideal.")
  autoRespondSMS  Boolean  @default(true)
  autoRespondEmail Boolean @default(true)
  autoFollowUp    Boolean  @default(true)
  autoCallEnabled Boolean  @default(true)
  leadScoreThreshold Int   @default(50)
  followUpDelayHours Int   @default(2)
  realtorName     String   @default("Catherine")
  realtorPhone    String?
  realtorEmail    String?
  calendlyUrl     String?
  zoomLink        String?
  voicemailMsg    String?
  agentLanguage   String   @default("es")
  preQualEnabled  Boolean  @default(true)
  updatedAt       DateTime @updatedAt
}

model WebsiteConfig {
  id                String   @id @default(cuid())
  // Hero
  heroTitle         String   @default("Your Dream Home Awaits")
  heroSubtitle      String   @default("Luxury real estate with a personal touch")
  heroImageUrl      String?
  heroCta           String   @default("View Listings")
  heroCta2          String   @default("Contact Me")
  // Agent
  agentName         String   @default("Catherine Gomez")
  agentTitle        String   @default("Luxury Real Estate Specialist")
  agentPhone        String?
  agentEmail        String?
  agentPhotoUrl     String?
  agentBio          String   @default("With over 15 years of experience in Miami's luxury real estate market, I bring unmatched expertise and dedication to every transaction.")
  agentLicense      String?
  agentBrokerage    String?
  agentAddress      String?
  agentWebsite      String?
  // Stats
  yearsFounded      Int      @default(2009)
  homesSold         Int      @default(500)
  satisfiedClients  Int      @default(98)
  avgDaysOnMarket   Int      @default(21)
  // Branding
  primaryColor      String   @default("#0e8fe9")
  accentColor       String   @default("#c9a84c")
  logoUrl           String?
  // Social
  facebook          String?
  instagram         String?
  linkedin          String?
  youtube           String?
  whatsapp          String?
  // Content
  aboutHeading      String   @default("Why Work With Me")
  testimonials      String   @default("[]")
  serviceAreas      String   @default("[]")
  videoUrl          String?
  // SEO
  metaTitle         String?
  metaDescription   String?
  updatedAt         DateTime @updatedAt
}

// ─── IDX / Property Search ────────────────────────────────────────────────────

model PropertySave {
  id            String    @id @default(cuid())
  contactId     String
  contact       Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  propertyId    String
  property      Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  isActive      Boolean   @default(true)
  aiTriggered   Boolean   @default(false)
  aiTriggeredAt DateTime?
  createdAt     DateTime  @default(now())
  @@unique([contactId, propertyId])
}

model PropertyView {
  id          String    @id @default(cuid())
  contactId   String?
  contact     Contact?  @relation(fields: [contactId], references: [id])
  propertyId  String
  property    Property  @relation(fields: [propertyId], references: [id])
  sessionId   String?
  durationSec Int?
  createdAt   DateTime  @default(now())
}

model SearchBehavior {
  id          String    @id @default(cuid())
  contactId   String?
  contact     Contact?  @relation(fields: [contactId], references: [id])
  sessionId   String?
  searchQuery String
  minPrice    Float?
  maxPrice    Float?
  bedrooms    Int?
  bathrooms   Float?
  propertyType String?
  location    String?
  resultCount Int       @default(0)
  createdAt   DateTime  @default(now())
}

// ─── Power Dialer ─────────────────────────────────────────────────────────────

model DialerSession {
  id            String        @id @default(cuid())
  name          String
  agentId       String
  status        String        @default("ACTIVE")
  calls         DialerCall[]
  totalCalls    Int           @default(0)
  answered      Int           @default(0)
  voicemails    Int           @default(0)
  noAnswers     Int           @default(0)
  activeCallSid String?       // Twilio SID of the first answered call
  agentIdentity String?       // Twilio Client identity for this session
  createdAt     DateTime      @default(now())
  endedAt       DateTime?
}

model DialerCall {
  id           String         @id @default(cuid())
  session      DialerSession? @relation(fields: [sessionId], references: [id])
  sessionId    String?
  contactId    String?
  contact      Contact?       @relation(fields: [contactId], references: [id])
  phoneNumber  String
  status       String         @default("QUEUED")
  direction    String         @default("OUTBOUND")
  duration     Int?
  recordingUrl  String?
  transcription String?
  aiSummary     String?
  notes         String?
  disposition   String?
  twilioSid    String?
  agentId      String?
  startedAt    DateTime?
  endedAt      DateTime?
  createdAt    DateTime       @default(now())
}

// ─── Instagram Lead Bot ───────────────────────────────────────────────────────

model InstagramConversation {
  id              String    @id @default(cuid())
  igUserId        String    @unique
  igUsername      String?
  state           String    @default("ASKED_OPTIN")
  firstName       String?
  email           String?
  phone           String?
  intent          String?
  contactId       String?
  sourceCommentId String?
  campaignKeyword String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ─── Loan Officer Partner Portal ──────────────────────────────────────────────

model LoanOfficer {
  id                   String      @id @default(cuid())
  name                 String
  email                String      @unique
  passwordHash         String
  company              String?
  phone                String?
  isActive             Boolean     @default(true)
  monthlyFee           Float       @default(99)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  subscriptionStatus   String      @default("inactive") // active | inactive | past_due | canceled
  subscriptionEndDate  DateTime?
  pricePerLead         Float       @default(25) // legacy: kept for historical per-lead shares
  leadShares           LeadShare[]
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
}

model LeadShare {
  id              String          @id @default(cuid())
  contact         Contact         @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId       String
  loanOfficer     LoanOfficer     @relation(fields: [loanOfficerId], references: [id], onDelete: Cascade)
  loanOfficerId   String
  price           Float
  status          String          @default("PENDING") // PENDING (awaiting payment) | PAID | REVOKED
  paidAt          DateTime?
  stripeSessionId String?
  loStatus        String          @default("NEW") // NEW | CONTACTED | PRE_APPROVED | DOCS_REQUESTED | CLOSED | LOST
  notes           LeadShareNote[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([contactId, loanOfficerId])
}

model LeadShareNote {
  id          String    @id @default(cuid())
  leadShare   LeadShare @relation(fields: [leadShareId], references: [id], onDelete: Cascade)
  leadShareId String
  author      String    @default("LO") // LO | ADMIN
  content     String
  createdAt   DateTime  @default(now())
}

model InstagramBotConfig {
  id              String   @id @default(cuid())
  isEnabled       Boolean  @default(false)
  triggerKeywords String   @default("info,más info,mas info,interesado,precio,price,interested,details,detalles,casa,comprar,invest,miami,hola,interesa,preconstruccion,preconstrucción")
  msgGreeting     String   @default("¡Hola! 👋 Gracias por tu interés en nuestros proyectos en Miami y Homestead. ¿Te gustaría recibir nuestra lista exclusiva de casas en preconstrucción o nuestro paquete de inversión para Airbnb y rentas cortas? Responde SÍ y te la envío 🏠")
  msgAskIntent    String   @default("¡Perfecto! 🎉 Antes de enviarte la información, para ayudarte mejor... ¿Estás interesado en:\n\nA) Comprar para vivir\nB) Invertir para Airbnb\nC) Solo explorando\n\nResponde A, B o C")
  msgAskName      String   @default("¡Excelente! ¿Cuál es tu nombre completo?")
  msgAskEmail     String   @default("Mucho gusto, {name}! Para enviarte el catálogo completo y planos de los proyectos, ¿me puedes escribir tu correo electrónico? 📧")
  msgAskPhone     String   @default("¡Perfecto! Una última cosa... ¿Podrías compartirme tu número de teléfono con código de país? Ejemplo: +1 786 123 4567 📱 (usa el número correcto, no te vamos a molestar)")
  msgThankYou     String   @default("¡Muchas gracias {name}! 🙌 Ya tenemos tu información. Catherine te contactará muy pronto con las mejores opciones. Mientras tanto puedes visitar nuestra página web: {website}")
  websiteUrl      String   @default("https://catherinegomezrealtor.com")
  greetingButtons String   @default("Sí, me interesa,Quiero más info")
  intentButtonA   String   @default("Comprar para vivir")
  intentButtonB   String   @default("Invertir / Airbnb")
  intentButtonC   String   @default("Solo explorando")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model InstagramBotCampaign {
  id        String   @id @default(cuid())
  keyword   String   @unique
  keywords  String   @default("")
  name      String
  pdfUrl    String?
  pdfName   String?
  greeting  String?
  isActive  Boolean  @default(true)
  leads     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model ClientPortalAccess {
  id           String    @id @default(cuid())
  contactId    String    @unique
  contact      Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  token        String    @unique @default(cuid())
  passwordHash String?
  isActive     Boolean   @default(true)
  invitedAt    DateTime  @default(now())
  lastLoginAt  DateTime?
}

model PortalMessage {
  id         String   @id @default(cuid())
  contactId  String
  contact    Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  fromClient Boolean  @default(true)
  content    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
}

// ─── Facebook Messenger ───────────────────────────────────────────────────────

model FacebookMessage {
  id          String    @id @default(cuid())
  psid        String
  pageId      String    @default("")
  body        String
  direction   String    @default("INBOUND")
  status      String    @default("SENT")
  messageId   String?
  attachments String?
  contactId   String?
  contact     Contact?  @relation(fields: [contactId], references: [id])
  createdAt   DateTime  @default(now())
}

// ─── WhatsApp ─────────────────────────────────────────────────────────────────

model WhatsAppMessage {
  id          String    @id @default(cuid())
  body        String
  fromNumber  String
  toNumber    String
  direction   String    @default("OUTBOUND")
  status      String    @default("SENT")
  messageType String    @default("text")
  mediaUrl    String?
  twilioSid   String?
  contactId   String?
  contact     Contact?  @relation(fields: [contactId], references: [id])
  createdAt   DateTime  @default(now())
}

// ─── Video Messages ───────────────────────────────────────────────────────────

model VideoMessage {
  id           String    @id @default(cuid())
  title        String
  description  String?
  videoUrl     String
  thumbnailUrl String?
  duration     Int?
  views        Int       @default(0)
  sentVia      String?
  contactId    String?
  contact      Contact?  @relation(fields: [contactId], references: [id])
  createdAt    DateTime  @default(now())
}

// ─── Social Media ─────────────────────────────────────────────────────────────

model SocialAutoPilotConfig {
  id        String   @id @default(cuid())
  isEnabled Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SocialAccount {
  id                String       @id @default(cuid())
  platform          String
  accountId         String?
  accountName       String?
  accessToken       String?
  refreshToken      String?
  pageId            String?
  isConnected       Boolean      @default(false)
  subscribedToLeads Boolean      @default(false)
  posts             SocialPost[]
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

model SocialPost {
  id          String         @id @default(cuid())
  platform    String
  content     String
  mediaUrl    String?
  postType    String         @default("POST")
  status      String         @default("DRAFT")
  scheduledAt DateTime?
  publishedAt DateTime?
  externalId  String?
  reach       Int?
  likes       Int?
  comments    Int?
  shares      Int?
  accountId   String?
  account     SocialAccount? @relation(fields: [accountId], references: [id])
  aiGenerated Boolean        @default(false)
  prompt      String?
  errorMessage String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

// ─── Open House ───────────────────────────────────────────────────────────────

model OpenHouse {
  id         String             @id @default(cuid())
  address    String
  date       DateTime
  endTime    DateTime?
  notes      String?
  status     String             @default("UPCOMING")
  propertyId String?
  property   Property?          @relation(fields: [propertyId], references: [id])
  visitors   OpenHouseVisitor[]
  agentId    String?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
}

model OpenHouseVisitor {
  id          String    @id @default(cuid())
  openHouseId String
  openHouse   OpenHouse @relation(fields: [openHouseId], references: [id], onDelete: Cascade)
  firstName   String
  lastName    String
  email       String?
  phone       String?
  preApproved Boolean   @default(false)
  notes       String?
  contactId   String?
  createdAt   DateTime  @default(now())
}

// ─── Campaign Automation ──────────────────────────────────────────────────────

model CampaignEnrollment {
  id          String            @id @default(cuid())
  campaignId  String
  campaign    MarketingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contactId   String
  contact     Contact           @relation(fields: [contactId], references: [id], onDelete: Cascade)
  status      String            @default("ENROLLED")
  enrolledAt  DateTime          @default(now())
  completedAt DateTime?
  @@unique([campaignId, contactId])
}

// ─── Auto Power Dial Sessions ────────────────────────────────────────────────

model PowerDialSession {
  id            String   @id @default(cuid())
  status        String   @default("ACTIVE") // ACTIVE | COMPLETED | STOPPED
  contactQueue  String   // JSON: [{id,name,phone}]
  currentIndex  Int      @default(0)
  totalCount    Int      @default(0)
  currentCallId String?
  voicemailMsg  String?
  callLog       String   @default("[]") // JSON: [{name,phone,outcome,at}]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ─── Scheduled VAPI retry calls ──────────────────────────────────────────────

model ScheduledCall {
  id          String   @id @default(cuid())
  contactId   String
  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  scheduledAt DateTime
  status      String   @default("PENDING") // PENDING | FIRED | CANCELLED | EXPIRED
  attempt     Int      @default(1)
  createdAt   DateTime @default(now())
}

// ─── Property Alert Tracking ─────────────────────────────────────────────────

model PropertyAlertSent {
  id         String   @id @default(cuid())
  contactId  String
  propertyId String
  sentAt     DateTime @default(now())
  @@unique([contactId, propertyId])
}

// ─── Key-value settings store ────────────────────────────────────────────────

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ─── Facebook Comment Bot ─────────────────────────────────────────────────────

model FacebookBotConfig {
  id              String   @id @default(cuid())
  isEnabled       Boolean  @default(false)
  triggerKeywords String   @default("info,precio,interesado,quiero,casa,propiedad,apartamento,más info,mas info,comprar,miami,invest")
  msgGreeting     String   @default("¡Hola! 👋 Gracias por tu interés. Te enviamos un mensaje privado con información sobre propiedades en Miami. ¡Revisa tu bandeja de entrada de Messenger!")
  msgAskIntent    String   @default("¡Perfecto! Para ayudarte mejor, ¿qué estás buscando?\n\nA) Comprar para vivir\nB) Invertir (Airbnb/renta)\nC) Solo explorando")
  msgAskName      String   @default("¡Genial! ¿Cuál es tu nombre completo?")
  msgAskEmail     String   @default("Mucho gusto, {name}! ¿Cuál es tu correo electrónico? 📧")
  msgAskPhone     String   @default("¡Casi listo! ¿Me das tu número de teléfono con código de país? Ej: +1 786 123 4567 📱")
  msgThankYou     String   @default("¡Muchas gracias {name}! 🙌 Catherine te contactará muy pronto. Visita: {website}")
  sendListings    Boolean  @default(true)
  websiteUrl      String   @default("")
  greetingButtons String   @default("Sí, me interesa,Quiero más info")
  intentButtonA   String   @default("Comprar para vivir")
  intentButtonB   String   @default("Invertir / Airbnb")
  intentButtonC   String   @default("Solo explorando")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model FacebookBotConversation {
  id              String   @id @default(cuid())
  psid            String   @unique
  pageId          String   @default("")
  state           String   @default("ASKED_OPTIN")
  intent          String?
  firstName       String?
  email           String?
  phone           String?
  sourceCommentId String?
  contactId       String?
  campaignKeyword String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model FacebookBotCampaign {
  id        String   @id @default(cuid())
  keyword   String   @unique
  keywords  String   @default("")
  name      String
  pdfUrl    String?
  pdfName   String?
  greeting  String?
  isActive  Boolean  @default(true)
  leads     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── CMA Report ───────────────────────────────────────────────────────────────

model CMAReport {
  id             String    @id @default(cuid())
  title          String
  address        String
  bedrooms       Int?
  bathrooms      Float?
  sqft           Int?
  yearBuilt      Int?
  condition      String    @default("GOOD")
  notes          String?
  comps          String    @default("[]")
  estimatedMin   Float?
  estimatedMax   Float?
  estimatedValue Float?
  shareToken     String    @unique @default(cuid())
  contactId      String?
  agentId        String?
  isPublic       Boolean   @default(true)
  sentAt         DateTime?
  viewedAt       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ─── Blog ─────────────────────────────────────────────────────────────────────

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique @default(cuid())
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
}

// ─── Blog ─────────────────────────────────────────────────────────────────────

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String?
  content     String
  coverImage  String?
  author      String   @default("Catherine Gomez")
  tags        String   @default("[]")
  featured    Boolean  @default(false)
  published   Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Lead Magnets ─────────────────────────────────────────────────────────────

model LeadMagnet {
  id          String   @id @default(cuid())
  keyword     String   @unique
  title       String
  description String
  content     String   @db.Text
  scriptSource String? @db.Text
  pdfUrl      String?
  guideUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deliveries  LeadMagnetDelivery[]
}

model LeadMagnetDelivery {
  id           String     @id @default(cuid())
  keyword      String
  channel      String
  deliveredAt  DateTime   @default(now())
  contactId    String?
  contact      Contact?   @relation(fields: [contactId], references: [id])
  leadMagnet   LeadMagnet @relation(fields: [keyword], references: [keyword])
}
